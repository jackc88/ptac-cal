        print("Generating all variants...")

        # Full unfiltered
        text = fetch_page(args.url)
        events = parse_events(text, timed_only=False, allowed_groups=None, debug=args.debug)
        #generate_ics(events, 'all.ics')
        #print("Created: all.ics")

        # Per group
        for group in groups:
            events = parse_events(text, timed_only=True, allowed_groups={group}, debug=args.debug)
            filename = f"output/{group}.ics"
            generate_ics(events, filename)
            print(f"Created: {filename}")

        # Per location (requires adding location filter - see next section)
        # (add code here once location filter is implemented)

        print("All variants generated.")


    while True:
        try:
            text = fetch_page(args.url)
            events = parse_events(text,
                                  timed_only=args.timed_only,
                                  allowed_groups=allowed,
                                  debug=args.debug)
