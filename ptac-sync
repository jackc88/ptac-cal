    print(f"Timed-only: {'ON' if args.timed_only else 'OFF'}")
    print(f"Groups filter: {', '.join(sorted(allowed)) if allowed else 'ALL'}")
    print(f"Debug: {'ON' if args.debug else 'OFF'}")
